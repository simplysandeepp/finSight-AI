# ── FinSight AI Backend — Environment Variables ──
# Copy this file to .env and fill in your actual values.

# ════════════════════════════════════════════════════════════════
# REQUIRED — Core API Keys (system will fail without these)
# ════════════════════════════════════════════════════════════════

# ── LLM Provider Keys (at least ONE is required) ───────────────
# The system tries Groq first (with rotation), then falls back to Gemini.
# You can provide multiple Groq keys for rate limit rotation.
GROQ_API_KEY_1=your_groq_key_1          # https://console.groq.com/keys (FREE tier available)
# GROQ_API_KEY_2=your_groq_key_2        # Optional: add more keys for rotation
# GROQ_API_KEY_3=your_groq_key_3        # Optional: add more keys for rotation

GEMINI_API_KEY=your_gemini_key          # https://ai.google.dev/ (Fallback if Groq fails)

# ── Financial Data APIs (REQUIRED for predictions) ─────────────
FINNHUB_API_KEY=your_finnhub_key        # https://finnhub.io (FREE tier: 60 calls/min)
FRED_API_KEY=your_fred_key              # https://fred.stlouisfed.org/docs/api/api_key.html (FREE)
NEWS_API_KEY=your_newsapi_key           # https://newsapi.org (FREE tier: 100 req/day)

# ════════════════════════════════════════════════════════════════
# OPTIONAL — Advanced Features
# ════════════════════════════════════════════════════════════════

# ── MongoDB Atlas (optional: for audit logging & history) ──────
# If not provided, audit features will be disabled
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/finsight?retryWrites=true&w=majority

# ── Firebase Admin SDK (optional: for frontend auth) ───────────
# Only needed if you enable authentication in the frontend
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ════════════════════════════════════════════════════════════════
# OPTIONAL — System Configuration
# ════════════════════════════════════════════════════════════════

# ── Server Settings (defaults shown) ───────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS Origins (comma-separated, no spaces) ──────────────────
# Add your frontend URLs here (both dev and production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Synthetic Data Fallback ────────────────────────────────────
# Set to "true" only for testing without real APIs
ALLOW_SYNTHETIC_FALLBACK=false

# ════════════════════════════════════════════════════════════════
# DEPRECATED — No Longer Used
# ════════════════════════════════════════════════════════════════
# Alpha Vantage API Key (DEPRECATED - replaced by NewsAPI)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
